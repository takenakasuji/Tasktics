{
  "name": "tasktics",
  "version": "0.1.2",
  "description": "Military HUD-themed task management tool",
  "author": "takenakasuji",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "vitest": "^3.1.1"
  },
  "build": {
    "appId": "com.tasktics.app",
    "productName": "Tasktics",
    "files": [
      "src/**/*",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    }
  }
}
